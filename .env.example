APP_NAME="GJS - Go Journal System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Jakarta

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database ────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=gjs
DB_USERNAME=root
DB_PASSWORD=

# ─── Session ─────────────────────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SAME_SITE=lax

# ─── Cache & Queue ───────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@gjs.local"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Storage (S3/MinIO) ───────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=gjs-uploads
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_ENDPOINT=

# ─── Auth ─────────────────────────────────────────────────────────────────────
SUPER_ADMIN_EMAIL=admin@gjs.local
SUPER_ADMIN_PASSWORD=change-me-in-production

# ─── ORCID OAuth ─────────────────────────────────────────────────────────────
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=
ORCID_REDIRECT_URI="${APP_URL}/auth/orcid/callback"

# ─── Crossref DOI ─────────────────────────────────────────────────────────────
CROSSREF_USER=
CROSSREF_PASSWORD=
CROSSREF_DEPOSITOR_NAME=
CROSSREF_DEPOSITOR_EMAIL=

# ─── Plagiarism Check ─────────────────────────────────────────────────────────
ITHENTICATE_API_KEY=

# ─── Payment Gateway ──────────────────────────────────────────────────────────
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# ─── Meilisearch ─────────────────────────────────────────────────────────────
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_KEY=

# ─── Vite ────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
